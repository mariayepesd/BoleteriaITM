{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/gateway-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "JwtSettings": {
    "Authority": "https://localhost:5001",
    "Audience": "boletera-api",
    "ValidateAudience": true,
    "ValidateIssuer": true,
    "ValidateLifetime": true
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSizeSeconds": 60
  },
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "order-api",
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/orders/{**catch-all}"
          }
        ]
      },
      {
        "RouteId": "inventory-api",
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      },
      {
        "RouteId": "price-api",
        "ClusterId": "price-cluster",
        "Match": {
          "Path": "/api/prices/{**catch-all}"
        }
      },
      {
        "RouteId": "search-api",
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      },
      {
        "RouteId": "notification-hub",
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      }
    ],
    "Clusters": [
      {
        "ClusterId": "order-cluster",
        "Destinations": {
          "order-destination": {
            "Address": "http://order-service:8080"
          }
        }
      },
      {
        "ClusterId": "inventory-cluster",
        "Destinations": {
          "inventory-destination": {
            "Address": "http://inventory-service:8080"
          }
        }
      },
      {
        "ClusterId": "price-cluster",
        "Destinations": {
          "price-destination": {
            "Address": "http://price-service:8080"
          }
        }
      },
      {
        "ClusterId": "search-cluster",
        "Destinations": {
          "search-destination": {
            "Address": "http://search-service:8080"
          }
        }
      },
      {
        "ClusterId": "notification-cluster",
        "Destinations": {
          "notification-destination": {
            "Address": "http://notification-service:8080"
          }
        }
      }
    ]
  }
}
