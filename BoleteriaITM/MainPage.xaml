<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BoleteriaITM.MainPage"
             Title="ITM-Tickets"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- ══ HEADER ══ -->
            <Border StrokeShape="RoundRectangle 14"
                    BackgroundColor="{StaticResource Primary}"
                    StrokeThickness="0"
                    Padding="20,18">
                <VerticalStackLayout Spacing="4">
                    <Label Text="🎪 ITM-Tickets"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Festival de los Dos Mundos · The World Tour 2026"
                           FontSize="12" TextColor="#c4b5f4"
                           HorizontalOptions="Center"/>
                    <Label x:Name="LblSignalRStatus"
                           Text="● Conectando al servidor en tiempo real..."
                           FontSize="11" TextColor="#a5b4fc"
                           HorizontalOptions="Center"
                           Margin="0,6,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- ══ FORMULARIO DE COMPRA ══ -->
            <Border StrokeShape="RoundRectangle 14"
                    BackgroundColor="White"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray200}"
                    Padding="18">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Selecciona tu entrada"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>

                    <!-- Sede -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="SEDE DEL FESTIVAL"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource Gray200}"
                                Padding="4,0">
                            <Picker x:Name="PickerSede"
                                    Title="Elige la sede..."
                                    SelectedIndexChanged="OnSeleccionCambia">
                                <Picker.Items>
                                    <x:String>🇨🇴  Medellín, Colombia</x:String>
                                    <x:String>🇪🇸  Madrid, España</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Categoría -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="CATEGORÍA"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1"/>
                        <Border StrokeShape="RoundRectangle 8"
                                Stroke="{StaticResource Gray200}"
                                Padding="4,0">
                            <Picker x:Name="PickerCategoria"
                                    Title="Elige la categoría..."
                                    SelectedIndexChanged="OnSeleccionCambia">
                                <Picker.Items>
                                    <x:String>🎟  General</x:String>
                                    <x:String>⭐  VIP</x:String>
                                    <x:String>👑  Palco</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Cantidad -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="CANTIDAD"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1"/>
                        <HorizontalStackLayout Spacing="14" HorizontalOptions="Start">
                            <Button x:Name="BtnMenos" Text="−"
                                    Clicked="OnMenos"
                                    WidthRequest="46" HeightRequest="46"
                                    FontSize="22"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource Tertiary}"
                                    CornerRadius="8"/>
                            <Label x:Name="LblCantidad" Text="1"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}"
                                   VerticalOptions="Center"
                                   WidthRequest="36"
                                   HorizontalTextAlignment="Center"/>
                            <Button x:Name="BtnMas" Text="+"
                                    Clicked="OnMas"
                                    WidthRequest="46" HeightRequest="46"
                                    FontSize="22"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource Tertiary}"
                                    CornerRadius="8"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Panel de precio dinámico (Redis) -->
                    <Border x:Name="PanelPrecio"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{StaticResource Secondary}"
                            StrokeThickness="0"
                            Padding="14,10"
                            IsVisible="False">
                        <HorizontalStackLayout Spacing="10">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                <Label x:Name="LblPrecioTotal"
                                       FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource Tertiary}"/>
                                <Label x:Name="LblPrecioDetalle"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray600}"/>
                            </VerticalStackLayout>
                            <Label x:Name="LblCacheTag"
                                   Text="⚡ REDIS"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"
                                   IsVisible="False"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Botón de compra -->
                    <Button x:Name="BtnComprar"
                            Text="COMPRAR BOLETAS"
                            Clicked="OnComprar"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="10"
                            HeightRequest="54"
                            IsEnabled="False"
                            Margin="0,4,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- ══ PANEL DE ESTADO DE LA ORDEN ══ -->
            <Border x:Name="PanelEstado"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="White"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray200}"
                    Padding="18"
                    IsVisible="False">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Estado de tu compra"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}"/>

                    <HorizontalStackLayout Spacing="10">
                        <ActivityIndicator x:Name="Spinner"
                                           IsRunning="False"
                                           IsVisible="False"
                                           Color="{StaticResource Primary}"
                                           WidthRequest="22" HeightRequest="22"
                                           VerticalOptions="Center"/>
                        <Label x:Name="LblEstado"
                               Text=""
                               FontSize="13"
                               TextColor="{StaticResource Gray600}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Correlation ID (útil para la demo) -->
                    <Label x:Name="LblCorrelationId"
                           Text=""
                           FontSize="10"
                           TextColor="{StaticResource Gray400}"
                           IsVisible="False"/>

                    <!-- ✅ Boleta lista — se muestra al llegar el evento SignalR -->
                    <Border x:Name="PanelTicketListo"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="#f0fdf4"
                            StrokeThickness="1"
                            Stroke="#86efac"
                            Padding="14,12"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="🎟 ¡Tu boleta está lista!"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#15803d"/>
                            <Label Text="Notificación recibida vía SignalR en tiempo real"
                                   FontSize="11"
                                   TextColor="#4ade80"/>
                            <Label x:Name="LblOrdenInfo"
                                   Text=""
                                   FontSize="12"
                                   TextColor="#166534"/>
                            <Label x:Name="LblTicketUrl"
                                   Text=""
                                   FontSize="10"
                                   TextColor="#6b7280"
                                   LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
